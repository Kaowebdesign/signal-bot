# Database
DATABASE_URL="postgresql://user:password@db:5432/signalbot?schema=public"
DB_USER=user
DB_PASSWORD=change-me
DB_NAME=signalbot

# JWT
JWT_SECRET="change-me-to-a-long-random-string"

# Telegram MTProto (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_PHONE=

# Web Push VAPID keys (generate: node -e "const w=require('web-push'); console.log(w.generateVAPIDKeys())")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:your@email.com"

# Set to "true" to disable public registration
REGISTRATION_DISABLED=true
